{
  "name": "clauding",
  "version": "0.2.0",
  "private": true,
  "description": "Discord Rich Presence with Claude spinner verbs + Clawd rotation — daemon and VSCode extension",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "daemon": "pnpm --filter @clauding/daemon start",
    "daemon:dev": "pnpm --filter @clauding/daemon dev",
    "extension:package": "pnpm --filter @clauding/extension package",
    "process-stickers": "python3 scripts/process_stickers.py"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.29.3"
}
