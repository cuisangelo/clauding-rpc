{
  "name": "clauding",
  "displayName": "Clauding",
  "version": "0.2.0",
  "private": true,
  "description": "Discord Rich Presence with Claude Code spinner verbs and Clawd rotation — only active while VSCode/Cursor is open. Unofficial, fan-made; not affiliated with Anthropic.",
  "publisher": "cuisangelo",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/cuisangelo/clauding-rpc.git",
    "directory": "packages/extension"
  },
  "homepage": "https://github.com/cuisangelo/clauding-rpc#readme",
  "bugs": "https://github.com/cuisangelo/clauding-rpc/issues",
  "categories": ["Other"],
  "keywords": ["discord", "rich presence", "claude", "clawd", "presence"],
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./dist/extension.cjs",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      {
        "command": "clauding.restart",
        "title": "Clauding: Restart presence"
      },
      {
        "command": "clauding.stop",
        "title": "Clauding: Stop presence"
      }
    ],
    "configuration": {
      "title": "Clauding",
      "properties": {
        "clauding.discordClientId": {
          "type": "string",
          "default": "1506350478714208378",
          "description": "Discord Application ID. Defaults to the shared Clauding app (with all 14 Clawds pre-uploaded). Override with your own only if you want full control over the assets and stats."
        },
        "clauding.frameMs": {
          "type": "number",
          "default": 10000,
          "minimum": 5000,
          "description": "Milliseconds between dot frames. Discord rate-limits to ~5 updates per 20s, keep ≥5000."
        },
        "clauding.dotFrames": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 6,
          "description": "Number of dot frames per verb before rotating to the next verb + Clawd."
        },
        "clauding.stateText": {
          "type": "string",
          "default": "with Claude",
          "description": "Text shown below the verb in the Discord presence card."
        },
        "clauding.buttonLabel": {
          "type": "string",
          "default": "claude.com",
          "description": "Label for the link button. Leave empty to hide the button."
        },
        "clauding.buttonUrl": {
          "type": "string",
          "default": "https://claude.com",
          "description": "URL that the link button opens."
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --platform=node --target=node18 --format=cjs --external:vscode --outfile=dist/extension.cjs",
    "dev": "pnpm build --watch",
    "package": "pnpm build && vsce package --no-dependencies --out clauding.vsix",
    "publish": "pnpm build && vsce publish --no-dependencies"
  },
  "dependencies": {
    "@clauding/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
